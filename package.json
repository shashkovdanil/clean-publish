{
  "name": "clean-publish",
  "version": "6.0.5",
  "description": "Clean your package before publish",
  "keywords": [
    "clean",
    "npm",
    "package",
    "publish"
  ],
  "license": "MIT",
  "author": "Shashkov Danil <shashkovdanil@gmail.com>",
  "repository": "shashkovdanil/clean-publish",
  "bin": {
    "clean-publish": "clean-publish.js",
    "clear-package-json": "clear-package-json.js"
  },
  "type": "module",
  "types": "types.d.ts",
  "scripts": {
    "test:lint": "oxlint *.js test/*.js",
    "test:unit": "tsx node_modules/uvu/bin.js . 'test/[^/]+\\.test\\.js$'",
    "schema": "ts-json-schema-generator --path types.d.ts --type Config --no-type-check --out schema.json",
    "test": "pnpm run -r /^test:/",
    "clean-publish": "node ./clean-publish.js"
  },
  "dependencies": {
    "lilconfig": "^3.1.3",
    "picomatch": "^4.0.4",
    "tinyexec": "^1.1.1",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@logux/oxc-configs": "^0.4.0",
    "actions-up": "^1.14.1",
    "eslint-plugin-prefer-let": "^4.2.2",
    "multiocular": "^0.8.3",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "ts-json-schema-generator": "^2.9.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "uvu": "^0.5.6"
  },
  "engines": {
    "node": ">= 20.0.0"
  }
}
